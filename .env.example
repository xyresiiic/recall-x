# Example environment variables for local development.
# Copy this to a file named `.env` at the project root and fill in the real values.

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Optional: service role key for trusted server operations (never commit the real key)
SUPABASE_SERVICE_ROLE_KEY="sb_service_role_..."

# AI Gateway
# Provide a key for your AI gateway provider (e.g. Lovable gateway or other compatible gateway).
AI_GATEWAY_API_KEY="REPLACE_WITH_REAL_KEY"
# Optional: custom gateway base URL. Defaults to the provider's built-in URL.
AI_GATEWAY_URL="https://ai.gateway.example/v1"

# Local development overrides for Vite (optional)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
